// ============================================================
// Prisma Schema – Multi-Tenant WhatsApp KI-SaaS
// DSGVO-konform: Nachrichteninhalte verschlüsselt, Retention
// Policy pro Tenant, Consent-Tracking pro Conversation.
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Mandant / Kunde ----------
model Tenant {
  id               String         @id @default(cuid())
  name             String         // Firmenname des Kunden
  slug             String         @unique // URL-freundlicher Bezeichner
  whatsappPhoneId  String         @unique // WhatsApp Business Phone Number ID
  systemPrompt     String         @db.Text // KI-System-Prompt für diesen Mandanten
  brandName        String         // Markenname für KI-Antworten
  brandColor       String         @default("#000000") // Primärfarbe (Hex)
  retentionDays    Int            @default(90) // DSGVO: Aufbewahrungsfrist in Tagen
  dashboardToken   String?        @unique // SHA-256 Hash des Magic-Link Tokens
  dashboardTokenExpiresAt DateTime? // Ablaufzeitpunkt des Tokens
  dpaAcceptedAt    DateTime?      // DSGVO: Zeitpunkt der AVV-Akzeptierung
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())

  paddleCustomerId     String?    @unique
  paddleSubscriptionId String?
  paddlePlan           String?
  paddleStatus         String?    @default("inactive")
  billingEmail         String?

  hubspotApiKey        String?    @db.Text // AES-256-GCM verschlüsselt

  webWidgetEnabled    Boolean    @default(false) // Web-Widget aktiviert
  webWidgetPublicKey  String?    @unique          // Oeffentlicher Key (pub_xxx)
  webWidgetConfig     Json?                       // Widget-Config-Felder, siehe docs/decisions/phase-3b-spec-reconciliation.md

  conversations    Conversation[]
  leads            Lead[]
  campaigns        Campaign[]
  clients          Client[]
  assets           Asset[]
  assetCredit      AssetCredit?
  assetModels      TenantAssetModel[]

  @@map("tenants")
}

// ---------- Konversation / Chat-Session ----------
model Conversation {
  id                 String             @id @default(cuid())
  tenantId           String
  externalId         String?            // WhatsApp Chat-ID (gehashed) - fuer Web-Sessions NULL
  consentGiven       Boolean            @default(false) // DSGVO: Einwilligung erteilt
  consentAt          DateTime?          // Zeitpunkt der Einwilligung
  language           String             @default("de") // Erkannte Sprache (ISO 639-1)
  campaignSlug       String?            // Kampagnen-Tracking aus WhatsApp-Link
  leadSource         String?            // "qr", "link", "organic", "web"
  channel            Channel            @default(WHATSAPP) // Kanal: WhatsApp oder Web-Widget
  status             ConversationStatus @default(ACTIVE)
  widgetSessionToken String?            @unique // Web-Widget Session-Token (ws_xxx)
  widgetVisitorMeta  Json?              // Web-Widget: User-Agent, Referrer, Sprache
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages       Message[]
  lead           Lead?

  @@unique([tenantId, externalId])
  @@index([tenantId, status])
  @@index([tenantId, channel])
  @@index([tenantId, createdAt])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

// ---------- Nachricht ----------
model Message {
  id               String      @id @default(cuid())
  conversationId   String
  role             MessageRole // Absender: Nutzer, KI oder System
  contentEncrypted String      @db.Text // DSGVO: AES-256-GCM verschlüsselt
  messageType      MessageType @default(TEXT)
  timestamp        DateTime    @default(now())

  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, timestamp])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  LOCATION
  TEMPLATE
}

// ---------- Lead / Vertriebskontakt ----------
model Lead {
  id               String            @id @default(cuid())
  tenantId         String
  conversationId   String            @unique
  score            Int               @default(0) // Lead-Score (0–100)
  qualification    LeadQualification @default(UNQUALIFIED)
  appointmentAt    DateTime?         // Vereinbarter Termin
  status           LeadStatus        @default(NEW)
  pipelineStatus   PipelineStatus    @default(NEU) // CRM-Pipeline Spalte
  dealValue        Float?            // Deal-Wert in EUR
  notes            String?           @db.Text // Notizen zum Lead
  followUpCount    Int               @default(0) // Anzahl gesendeter Follow-Ups (0-3)
  lastFollowUpAt   DateTime?         // Zeitpunkt des letzten Follow-Ups
  aiSummary        String?           @db.Text // KI-generierte Lead-Zusammenfassung (JSON)
  aiSummaryAt      DateTime?         // Zeitpunkt der letzten KI-Analyse
  predictiveScore  String?           @db.Text // KI-Abschlusswahrscheinlichkeit (JSON)
  predictiveScoreAt DateTime?        // Zeitpunkt der letzten Prediction
  campaignId       String?           // Kampagnen-Zuordnung
  abTestVariant    String?           // "A" oder "B" – welche Variante wurde gesendet
  source           String?           // Lead-Quelle: "qr", "link", "organic", "broadcast"
  createdAt        DateTime          @default(now())

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation     Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  campaign         Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  client           Client?

  @@index([tenantId, status])
  @@index([tenantId, qualification])
  @@index([tenantId, pipelineStatus])
  @@index([campaignId])
  @@index([tenantId, createdAt])
  @@map("leads")
}

// ---------- Client / Gewonnener Kunde ----------
model Client {
  id              String       @id @default(cuid())
  tenantId        String
  leadId          String       @unique // 1:1 Verknüpfung zum Lead
  companyName     String       // Firmenname des Kunden
  contactName     String?      // Ansprechpartner
  status          ClientStatus @default(ONBOARDING)
  onboardingStep  Int          @default(0) // 0-5, aktueller Schritt
  milestones      String?      @db.Text // JSON Array der Meilensteine
  notes           String?      @db.Text // Freitext-Notizen
  docsGenerated   String?      @db.Text // KI-generierte Onboarding-Dokumente (JSON)
  createdAt       DateTime     @default(now())

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("clients")
}

enum ClientStatus {
  ONBOARDING
  ACTIVE
  PAUSED
}

// ---------- Kampagnen-Vorlage ----------
model CampaignTemplate {
  id            String   @id @default(cuid())
  tenantId      String?  // null = System-Template, gesetzt = benutzerdefiniert
  branche       String   // Immobilien, Handwerk, Coaching, Agentur, E-Commerce, Custom
  name          String   // Vorlagenname
  beschreibung  String?  @db.Text
  briefing      String   @db.Text // JSON: { ziel, zielgruppe, tonalitaet, ergebnis }
  openers       String   @db.Text // JSON: string[] (3 WhatsApp-Opener A/B/C)
  abVarianten   String?  @db.Text // JSON: { variantA, variantB } Vorschlag
  ziele         String   @db.Text // JSON: string[] (Terminbuchung, Angebot, etc.)
  isSystem      Boolean  @default(false) // System-Template vs. benutzerdefiniert
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([branche])
  @@map("campaign_templates")
}

// ---------- Kampagne / Tracking ----------
model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // Kampagnenname (z.B. "Facebook Ads Q1")
  slug        String   // URL-Slug für Tracking-Links
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isTemplate  Boolean  @default(false) // Als wiederverwendbares Template markiert
  templateData String? @db.Text // Briefing-Daten als JSON (audience, offer, tone)
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads       Lead[]
  abTests     AbTest[]
  broadcasts  Broadcast[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("campaigns")
}

// ---------- A/B Test ----------
model AbTest {
  id           String    @id @default(cuid())
  campaignId   String
  variantA     String    @db.Text // WhatsApp-Opener Variante A
  variantB     String    @db.Text // WhatsApp-Opener Variante B
  sendsA       Int       @default(0) // Anzahl gesendeter Variante A
  sendsB       Int       @default(0) // Anzahl gesendeter Variante B
  responsesA   Int       @default(0) // Antworten auf Variante A
  responsesB   Int       @default(0) // Antworten auf Variante B
  winnerId     String?   // "A" oder "B" oder null
  isActive     Boolean   @default(true)
  startedAt    DateTime  @default(now())
  endedAt      DateTime? // Automatisch nach 14 Tagen

  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, isActive])
  @@map("ab_tests")
}

// ---------- Broadcast ----------
model Broadcast {
  id           String              @id @default(cuid())
  tenantId     String
  campaignId   String?
  message      String              @db.Text // WhatsApp-Nachricht
  segment      String              // Segment-Filter als JSON
  totalSent    Int                 @default(0)
  totalFailed  Int                 @default(0)
  status       BroadcastStatus     @default(PENDING)
  createdAt    DateTime            @default(now())
  sentAt       DateTime?

  campaign     Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  recipients   BroadcastRecipient[]

  @@index([tenantId, status])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id           String   @id @default(cuid())
  broadcastId  String
  leadId       String
  status       String   @default("pending") // pending, sent, failed
  error        String?
  sentAt       DateTime?

  broadcast    Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, status])
  @@map("broadcast_recipients")
}

enum BroadcastStatus {
  PENDING
  SENDING
  COMPLETED
  FAILED
}

// ---------- Deduplizierung: Verarbeitete WhatsApp Message-IDs ----------
model ProcessedMessage {
  id        String   @id @default(cuid())
  messageId String   @unique // WhatsApp Message ID (wamid.xxx)
  createdAt DateTime @default(now())

  @@index([createdAt]) // Für 24h-Cleanup im DSGVO-Cron
  @@map("processed_messages")
}

enum LeadQualification {
  UNQUALIFIED
  MARKETING_QUALIFIED  // MQL
  SALES_QUALIFIED      // SQL
  OPPORTUNITY
  CUSTOMER
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT_SET
  CONVERTED
  LOST
}

enum PipelineStatus {
  NEU
  QUALIFIZIERT
  TERMIN
  ANGEBOT
  GEWONNEN
}

// ---------- AI Asset Studio ----------

// Generiertes oder bearbeitetes Asset (Bild, Grafik etc.)
model Asset {
  id              String      @id @default(cuid())
  tenantId        String
  originalPrompt  String      @db.Text // Ursprünglicher Generierungs-Prompt
  modelUsed       AssetModel  // Welches KI-Modell wurde verwendet
  status          AssetStatus @default(PENDING)
  imageUrl        String?     @db.Text // URL zum generierten Bild (Vercel Blob o.ä.)
  thumbnailUrl    String?     @db.Text // Vorschau-URL
  exportedFormats String?     @db.Text // JSON: ["png", "webp", "svg"]
  versionHistory  String?     @db.Text // JSON: Array max 10 Einträge [{prompt, modelUsed, imageUrl, createdAt}]
  creditsUsed     Int         @default(1) // Credits für diese Generierung
  width           Int?        // Bildbreite in px
  height          Int?        // Bildhöhe in px
  fileSize        Int?        // Dateigröße in Bytes
  editParams      String?     @db.Text // JSON: Bearbeitungs-Parameter (sharpen, roundCorners, brandKit)
  brandKit        String?     // Verwendetes Brand-Kit (z.B. "premium-gold")
  tags            String?     @db.Text // JSON: string[] für Suche/Filter
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, modelUsed])
  @@index([tenantId, createdAt])
  @@map("assets")
}

// Credit-Kontingent pro Tenant für Asset Studio
model AssetCredit {
  id              String   @id @default(cuid())
  tenantId        String   @unique // 1:1 pro Tenant
  monthlyIncluded Int      @default(50) // Inklusive Generierungen pro Monat
  used            Int      @default(0) // Verbrauchte Credits im aktuellen Monat
  bonusCredits    Int      @default(0) // Zusätzlich gekaufte Credits
  resetAt         DateTime // Nächster Monatswechsel-Reset
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("asset_credits")
}

// Aktivierte Modelle pro Tenant (1 bis 4 Modelle aktivierbar)
model TenantAssetModel {
  id        String     @id @default(cuid())
  tenantId  String
  model     AssetModel
  isActive  Boolean    @default(true)
  apiKeyRef String?    // Referenz auf env-Variable (z.B. "REPLICATE_API_KEY"), NICHT der Key selbst
  createdAt DateTime   @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, model])
  @@index([tenantId, isActive])
  @@map("tenant_asset_models")
}

enum AssetModel {
  GROK
  CLAUDE
  GEMINI
  FLUX
}

enum AssetStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  EDITED
}

// ---------- Kanal-Enum (Web-Widget Phase 2) ----------
enum Channel {
  WHATSAPP
  WEB
}
