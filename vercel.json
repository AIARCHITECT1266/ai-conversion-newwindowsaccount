{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ],
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?!facebookexternalhit|WhatsApp|Twitterbot).*"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ],
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "facebookexternalhit|WhatsApp|Twitterbot"
        }
      ]
    }
  ]
}
