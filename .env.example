# ============================================================
# AI Conversion – Environment Variables
# Kopiere diese Datei als .env.local und fülle die Werte aus.
# NIEMALS .env.local committen!
# ============================================================

# ---------- Datenbank (Prisma Postgres) ----------
DATABASE_URL=postgres://user:password@db.prisma.io:5432/postgres?sslmode=require

# ---------- KI-Provider ----------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---------- WhatsApp Cloud API ----------
WHATSAPP_TOKEN=EAAx...
WHATSAPP_PHONE_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=dein-verify-token
WHATSAPP_APP_SECRET=abcdef1234567890

# ---------- Admin-Dashboard ----------
ADMIN_SECRET=64-zeichen-hex-secret

# ---------- Verschlüsselung (AES-256-GCM) ----------
ENCRYPTION_KEY=64-zeichen-hex-key

# ---------- Cron-Job Absicherung ----------
CRON_SECRET=64-zeichen-hex-secret

# ---------- Paddle (Zahlungen) ----------
PADDLE_API_KEY=pdl_...
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_STARTER_MONTHLY=pri_...
PADDLE_PRICE_STARTER_YEARLY=pri_...
PADDLE_PRICE_STARTER_SETUP=pri_...
PADDLE_PRICE_GROWTH_MONTHLY=pri_...
PADDLE_PRICE_GROWTH_YEARLY=pri_...
PADDLE_PRICE_GROWTH_SETUP=pri_...
PADDLE_PRICE_PRO_MONTHLY=pri_...
PADDLE_PRICE_PRO_YEARLY=pri_...
PADDLE_PRICE_PRO_SETUP=pri_...

# ---------- E-Mail (Resend) ----------
RESEND_API_KEY=re_...

# ---------- Notion (Session Notes) ----------
NOTION_API_KEY=ntn_...
NOTION_SESSION_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------- Upstash Redis (Rate-Limiting + Sessions) ----------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...
